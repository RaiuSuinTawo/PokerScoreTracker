# ==== Database ====
DATABASE_URL="file:./data/holdem.db"

# ==== JWT ====
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET="change-me-access-secret-at-least-32-chars-long-please"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-32-chars-long-please"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ==== Server ====
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN="http://localhost:5173,http://localhost:8080"

# ==== Seed / Initial Admin ====
ADMIN_USERNAME=root
ADMIN_INITIAL_PASSWORD=ChangeMe!2026
ADMIN_DISPLAY_NAME=Root

# ==== Argon2 (optional tuning) ====
ARGON_MEMORY=65536
ARGON_TIME=3
ARGON_PARALLELISM=1
